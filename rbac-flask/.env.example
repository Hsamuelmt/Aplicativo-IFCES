# Rename this file to .env and fill values
# Flask
SECRET_KEY=change-this-in-production

# Database (choose one)
# 1) Render / PostgreSQL / production
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# 2) MySQL (local development / phpMyAdmin)
DB_NAME=flask_roles
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# 3) If you leave DB_NAME or DB_USER empty, app will use SQLite at instance/app.db
