# ============================================
# Flask Configuration
# ============================================
# Rename this file to .env and fill in actual values
FLASK_ENV=production
SECRET_KEY=change-this-to-a-secure-random-key-in-production

# ============================================
# Database Configuration
# ============================================
# Choose ONE of the following three options:

# OPTION 1: Render.com with PostgreSQL (RECOMMENDED for production)
# Render provides DATABASE_URL automatically, just uncomment:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# OPTION 2: MySQL (for FreeHostia or other MySQL hosts)
# Use these variables to connect to MySQL:
# DB_NAME=sammor96_sammor96_
# DB_USER=sammor96_user
# DB_PASSWORD=your_mysql_password
# DB_HOST=your_mysql_host.freehostia.com
# DB_PORT=3306

# OPTION 3: SQLite (development only)
# Leave all DB_* variables empty or commented out
# App will automatically fall back to instance/app.db

# ============================================
# Application Settings
# ============================================
DEBUG=False
